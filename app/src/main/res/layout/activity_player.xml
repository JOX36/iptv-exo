<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- LIVE: PlayerView fullscreen -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000" />

    <!-- LIVE top bar (tap para mostrar/ocultar) -->
    <LinearLayout
        android:id="@+id/live_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/live_btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF"
            android:contentDescription="Atras" />

        <TextView
            android:id="@+id/live_txt_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingStart="10dp" />

        <TextView
            android:id="@+id/live_txt_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#ff4444"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingEnd="8dp" />

        <ImageButton
            android:id="@+id/live_btn_fav"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Favorito" />

    </LinearLayout>

    <!-- LIVE bottom bar -->
    <LinearLayout
        android:id="@+id/live_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <!-- EPG info row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:id="@+id/live_epg_container">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="3dp">

                <TextView
                    android:id="@+id/live_epg_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EN VIVO"
                    android:textColor="#00d4ff"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="#221a2535"
                    android:padding="3dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/live_epg_now"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#e0f4ff"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/live_epg_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7ab8cc"
                    android:textSize="10sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/live_epg_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:progressTint="#00d4ff"
                android:progressBackgroundTint="#1a2535"
                android:max="100"
                android:layout_marginBottom="3dp" />

            <TextView
                android:id="@+id/live_epg_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#4a7a8a"
                android:textSize="10sp"
                android:ellipsize="end"
                android:maxLines="1" />

        </LinearLayout>

        <!-- Buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

        <Button
            android:id="@+id/live_btn_audio"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Audio"
            android:textSize="11sp"
            android:backgroundTint="#1a2535"
            android:textColor="#7ab8cc"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/live_btn_subs"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Subs"
            android:textSize="11sp"
            android:backgroundTint="#1a2535"
            android:textColor="#7ab8cc"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/live_btn_pip"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="PiP"
            android:textSize="11sp"
            android:backgroundTint="#1a2535"
            android:textColor="#7ab8cc"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/live_btn_ext"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Externo"
            android:textSize="11sp"
            android:backgroundTint="#1a2535"
            android:textColor="#7ab8cc"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/live_btn_stop"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Detener"
            android:textSize="11sp"
            android:backgroundTint="#55ef4444"
            android:textColor="#ef4444" />

        </LinearLayout>

    </LinearLayout>

    <!-- VOD/SERIES: layout vertical -->
    <LinearLayout
        android:id="@+id/vod_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0a0e14"
        android:visibility="gone">

        <!-- Video 40% con topbar transparente -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4">

            <androidx.media3.ui.PlayerView
                android:id="@+id/vod_player_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000" />

            <LinearLayout
                android:id="@+id/vod_top_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:background="#AA000000"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/vod_btn_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_media_previous"
                    android:tint="#00d4ff"
                    android:contentDescription="Atras" />

                <TextView
                    android:id="@+id/vod_txt_title_bar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="6dp" />

                <ImageButton
                    android:id="@+id/vod_btn_fav"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/btn_star_big_off"
                    android:contentDescription="Favorito" />

            </LinearLayout>

        </FrameLayout>

        <!-- Info 60% scrolleable -->
        <ScrollView
            android:id="@+id/vod_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="6"
            android:background="#0d1219">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/vod_txt_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#e0f4ff"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/vod_txt_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#1a2535"
                        android:textColor="#7ab8cc"
                        android:textSize="11sp"
                        android:padding="4dp"
                        android:layout_marginEnd="6dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/vod_txt_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#1a2535"
                        android:textColor="#7ab8cc"
                        android:textSize="11sp"
                        android:padding="4dp"
                        android:layout_marginEnd="6dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/vod_txt_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#ffc107"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:padding="4dp"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/vod_txt_plot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#7ab8cc"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="14dp" />

                <!-- Fila 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/vod_btn_fullscreen"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Pantalla completa"
                        android:textSize="11sp"
                        android:backgroundTint="#1a3550"
                        android:textColor="#00d4ff"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/vod_btn_pip"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="PiP"
                        android:textSize="11sp"
                        android:backgroundTint="#1a2535"
                        android:textColor="#7ab8cc" />

                </LinearLayout>

                <!-- Fila 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/vod_btn_ext"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Externo"
                        android:textSize="11sp"
                        android:backgroundTint="#1a2535"
                        android:textColor="#7ab8cc"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/vod_btn_copy"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Copiar URL"
                        android:textSize="11sp"
                        android:backgroundTint="#1a2535"
                        android:textColor="#7ab8cc"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/vod_btn_stop"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Detener"
                        android:textSize="11sp"
                        android:backgroundTint="#55ef4444"
                        android:textColor="#ef4444" />

                </LinearLayout>

                <!-- Fila 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/vod_btn_audio"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Audio"
                        android:textSize="11sp"
                        android:backgroundTint="#1a2535"
                        android:textColor="#7ab8cc"
                        android:layout_marginEnd="8dp"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/vod_btn_subs"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Subtitulos"
                        android:textSize="11sp"
                        android:backgroundTint="#1a2535"
                        android:textColor="#7ab8cc"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- VOD FULLSCREEN top -->
    <LinearLayout
        android:id="@+id/vod_fs_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <Button
            android:id="@+id/vod_fs_btn_exit"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Salir"
            android:textSize="11sp"
            android:backgroundTint="#1a2535"
            android:textColor="#00d4ff"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/vod_fs_txt_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

    </LinearLayout>

    <!-- VOD FULLSCREEN bottom -->
    <LinearLayout
        android:id="@+id/vod_fs_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center"
        android:visibility="gone">

        <Button
            android:id="@+id/vod_fs_btn_pip"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="PiP"
            android:textSize="11sp"
            android:backgroundTint="#1a2535"
            android:textColor="#7ab8cc"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/vod_fs_btn_ext"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Externo"
            android:textSize="11sp"
            android:backgroundTint="#1a2535"
            android:textColor="#7ab8cc"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/vod_fs_btn_url"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Copiar URL"
            android:textSize="11sp"
            android:backgroundTint="#1a2535"
            android:textColor="#7ab8cc"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/vod_fs_btn_subs"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Subtitulos"
            android:textSize="11sp"
            android:backgroundTint="#1a2535"
            android:textColor="#7ab8cc"
            android:visibility="gone" />

    </LinearLayout>

    <!-- LOADING -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#CC000000"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:indeterminateTint="#00d4ff" />

        <TextView
            android:id="@+id/txt_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Conectando..."
            android:textColor="#7ab8cc"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />

    </LinearLayout>

    <!-- DEBUG OVERLAY — temporal para diagnóstico -->
    <TextView
        android:id="@+id/debug_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:background="#AA000000"
        android:textColor="#00FF88"
        android:textSize="10sp"
        android:padding="6dp"
        android:fontFamily="monospace"
        android:visibility="gone" />

    <!-- SIGUIENTE EPISODIO — overlay cuenta regresiva -->
    <LinearLayout
        android:id="@+id/next_ep_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/next_ep_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:maxWidth="220dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Siguiente episodio" />

        <TextView
            android:id="@+id/next_ep_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#00D4FF"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:text="En 5 segundos..." />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/next_ep_btn_now"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="▶ Ahora"
                android:textSize="12sp"
                android:backgroundTint="#00D4FF"
                android:textColor="#000000"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <Button
                android:id="@+id/next_ep_btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="✕ Cancelar"
                android:textSize="12sp"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
